# Local development — backend runs over HTTPS (see backend/run_https.py)
# because the Excel Live add-in's task pane is HTTPS-only and calls it
# directly; this app can be plain HTTP and still call an HTTPS API fine.
VITE_API_URL=https://localhost:8000

# Production (set this in Vercel Environment Variables)
# VITE_API_URL=https://your-backend.onrender.com

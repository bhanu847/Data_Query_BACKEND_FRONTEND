# ── Auth ──
JWT_SECRET=your-secure-random-string-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Database ──
# Local: sqlite:///./dataquery.db
# Render Postgres: postgresql://user:pass@host:5432/dataquery
DATABASE_URL=sqlite:///./dataquery.db

# ── AI (optional — app works without it using pandas-only logic) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── File uploads ──
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# ── CORS — comma-separated origins ──
# Local dev:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production (set to your Vercel URL):
# CORS_ORIGINS=https://your-app.vercel.app
